{
  "manifest_name": "TS2000 Core 29",
  "description": "멘토 피드백과 후속 검증을 반영해 정리한 공식 29개 feature set입니다. 설명 가능성과 성능의 균형을 위해 gross_profit, listed_year, accruals_ratio, depreciation, cash_ratio, net_margin_diff를 포함합니다.",
  "dataset_file": "TS2000_Credit_Model_Dataset_Model_V1.csv",
  "target_column": "is_speculative",
