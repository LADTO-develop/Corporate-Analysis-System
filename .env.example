# ---------------------------------------------------------------------------
# Borderline Firm Detector — environment variables template
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- LLM providers ---------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Optional fallbacks / comparison models
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Bank of Korea ECOS ----------------------------------------------------
# Issue a key at https://ecos.bok.or.kr/api/
ECOS_API_KEY=

# --- TabPFN ----------------------------------------------------------------
# Where tabpfn caches its checkpoint. Defaults to ~/.cache/tabpfn/ on Linux.
TABPFN_MODEL_CACHE_DIR=

# --- TS2000 ----------------------------------------------------------------
# Path to the directory holding the five-file TS2000 export.
BFD_TS2000_ROOT=./data/raw/ts2000

# --- Internal info channel -------------------------------------------------
# One of: disabled, read_only, full. See docs/security_policy.md.
BFD_INTERNAL_INFO_MODE=disabled
# Audit log sink. Supports: stdout, file://path, syslog.
BFD_AUDIT_SINK=stdout

# --- Runtime ---------------------------------------------------------------
BFD_LOG_LEVEL=INFO
BFD_RANDOM_SEED=42
